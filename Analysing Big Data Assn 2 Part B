    "import pandas as pd\n",
    "\n",
    "frames = []\n",
    "for fpath in selected_files:\n",
    "    print(\"Loading:\", fpath.name)\n",
    "    tmp = pd.read_csv(fpath)\n",
    "\n",
    "    tmp.columns = [c.strip().lower() for c in tmp.columns]\n",
    "\n",
    "    if \"symbol\" not in tmp.columns:\n",
    "        tmp[\"symbol\"] = fpath.stem\n",
    "\n",
    "    keep = [\"date\", \"volume\", \"open\", \"high\", \"low\", \"close\", \"adjclose\", \"symbol\"]\n",
    "    cols_present = [c for c in keep if c in tmp.columns]\n",
    "    tmp = tmp[cols_present]\n",
    "\n",
    "    frames.append(tmp)\n",
    "\n",
    "df = pd.concat(frames, ignore_index=True)\n",
    "print(\"Combined shape:\", df.shape)\n",
    "df.head()"
   ]
